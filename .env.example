# ==============================================================================
# Student Management System - Environment Variables Example
# Copy this file to '.env' and fill in your actual production credentials.
# ==============================================================================

# Application Settings
SPRING_PROFILES_ACTIVE=prod
APP_BASE_URL=https://your-backend-service.onrender.com
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Database Configuration (PostgreSQL / Supabase / Railway)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_db_password

# JWT Secrets (Minimum 256-bit Hexadecimal string)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# Storage Configurations (local / s3 / cloudflare)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Mail Settings (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail-account@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_FROM=noreply@sms.edu

# OpenRouter AI Integration
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
AI_MODEL=mistralai/mistral-7b-instruct:free
